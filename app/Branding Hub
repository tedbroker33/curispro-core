  const loadData = async () => {
    try {
      const currentUser = await base44.auth.me();
      setUser(currentUser);

      const tasksData = await base44.entities.BrandingTask.filter({ agent_email: currentUser.email });
      setBrandingTasks(tasksData);
      setCompletedTasks(tasksData.filter(t => t.status === 'completed'));
