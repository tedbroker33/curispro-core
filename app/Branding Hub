        await base44.entities.BrandingTask.update(existingTask.id, {
          status: 'completed',
          completed_date: new Date().toISOString().split('T')[0]
        });
      } else {
        await base44.entities.BrandingTask.create({
          agent_email: user.email,
          task_type: 'google_business',
          title: taskTitle,
          status: 'completed',
          completed_date: new Date().toISOString().split('T')[0]
        });
      }

      await base44.entities.Activity.create({
        agent_email: user.email,
        type: 'badge_earned',
        description: `Completed branding task: ${taskTitle}`,
        points: 15
      });

      toast.success('Task completed! +15 points');
      loadData();
    } catch (err) {
      console.error(err);
      toast.error('Failed to update task');
    }
  };

